# ToxiScan frontend — environment variables
# Copy to `.env.local` for local dev, or set in the Vercel dashboard
# (Project Settings -> Environment Variables) for production.

# Base URL of the deployed FastAPI backend (Render). No trailing slash.
# Falls back to http://localhost:8000 if unset (see lib/api.ts) — so this
# only strictly needs to be set for the PRODUCTION Vercel deployment, not
# local dev against a local backend.
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
