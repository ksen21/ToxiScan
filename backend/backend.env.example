# ToxiScan backend — environment variables
# Copy to `.env` for local dev, or set these in the Render dashboard
# (Settings -> Environment) for production.

# --- MongoDB (required) ---
# MongoDB Atlas connection string. Free-tier (M0) cluster, Mumbai region per
# decisions.md. Get this from Atlas -> Database -> Connect -> Drivers.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# --- AI APIs ---
# Required — used directly for OCR (vision) and ingredient/product-name
# extraction, and for Phase 10 "Good ingredients" verification.
# (Historical note: SPEC.md/build_plan.md originally planned to route this
# through "NaraRouter" — the actual implementation calls Groq directly. See
# CLAUDE.md for why.)
GROQ_API_KEY=

# Not currently used anywhere in the codebase — leftover from an earlier
# plan. Safe to leave blank; does not need to be set for the app to work.
GEMINI_API_KEY=

# --- Web Search (required for product-name lookup) ---
# Used by services/product_lookup.py and services/search.py (research URL
# enrichment). Free tier: 1,000 searches/month.
TAVILY_API_KEY=

# --- App config ---
# "development" or "production" — currently only used for informational
# logging, doesn't gate any behavior.
APP_ENV=production

# Comma-separated list of allowed frontend origins for CORS. MUST include
# your production Vercel URL, e.g.:
#   https://toxiscan.vercel.app,http://localhost:3000
# (keep localhost:3000 too if you still want to test against prod backend
# from a local frontend dev server)
ALLOWED_ORIGINS=http://localhost:3000
